---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About — Baptiste Garderes" description="About Baptiste Garderes">
  <section class="page">
    <div class="container">
      <h1>About me</h1>

      <div class="bio">
        <div class="text">
          <p>
            Hi, I'm <strong>Baptiste Garderes</strong> — a Mechanical Engineering major at the University of California, Riverside (Class of 2027) and a student athlete on the Cross Country and Track & Field teams.
          </p>
          <p>
            My engineering background started in high school as a student researcher at The Center for Advanced Studies and Research, where I worked on solar-powered hardware projects — including a waterless solar panel cleaning robot that won Best Engineering Project at the Ventura County Science Fair.
          </p>
          <p>
            At UCR, I also serve as an Academic Intervention Peer Mentor, helping first-year and transfer students build study systems and navigate campus resources, and I'm a member of the NCAA Student Athlete Advisory Committee (SAAC).
          </p>
        </div>
      </div>

      <div class="section">
        <h2>Skills</h2>
        <div class="skills-grid">
          <div class="skill-group">
            <h3>Languages</h3>
            <ul>
              <li>English (native)</li>
              <li>French (professional)</li>
            </ul>
          </div>
          <div class="skill-group">
            <h3>Tools &amp; Frameworks</h3>
            <ul>
              <li>SolidWorks (Certified Associate)</li>
              <li>IntelliJ IDEA</li>
              <li>Git / GitHub</li>
            </ul>
          </div>
          <div class="skill-group">
            <h3>Areas</h3>
            <ul>
              <li>Mechanical design</li>
              <li>Solar / renewable energy systems</li>
              <li>Team leadership</li>
              <li>Public speaking &amp; presentations</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="section">
        <h2>Honors &amp; Awards</h2>
        <ul class="awards">
          <li>1st Place Award in Engineering — Ventura County Science Fair (2023)</li>
          <li>"See the Future" Award — Cal-NRG (2023)</li>
          <li>SolidWorks Associate – Mechanical Design certification (Dassault Systèmes, 2023)</li>
        </ul>
      </div>

      <div class="section">
        <h2>Links</h2>
        <ul class="links">
          <li><a href="https://github.com/bgarderes" target="_blank" rel="noopener">GitHub</a></li>
          <li><a href="https://www.linkedin.com/in/baptistegarderes" target="_blank" rel="noopener">LinkedIn</a></li>
          <li><a href="mailto:baptistegarderes@gmail.com">Email</a></li>
        </ul>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page { padding: 4rem 2rem 6rem; }
  .container { max-width: 760px; margin: 0 auto; display: flex; flex-direction: column; gap: 3rem; }

  h1 { font-size: 2.5rem; font-weight: 800; letter-spacing: -0.03em; }

  .bio .text { display: flex; flex-direction: column; gap: 1rem; }
  .bio p { color: var(--muted); line-height: 1.8; font-size: 1rem; }
  .bio strong { color: var(--text); }

  .section { display: flex; flex-direction: column; gap: 1.25rem; }
  h2 { font-size: 1.25rem; font-weight: 700; color: var(--text); }

  .skills-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1.5rem; }
  .skill-group h3 { font-size: 0.85rem; font-weight: 600; color: var(--accent); margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .skill-group ul { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
  .skill-group li { color: var(--muted); font-size: 0.9rem; }

  .links { list-style: none; display: flex; gap: 1.5rem; }
  .links a { color: var(--accent); text-decoration: none; font-size: 0.95rem; }
  .links a:hover { text-decoration: underline; }

  .awards { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .awards li { color: var(--muted); font-size: 0.9rem; line-height: 1.6; }
</style>
