---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = [
  {
    title: 'Waterless Solar Panel Cleaning Robot',
    description: 'Designed and built a solar panel cleaning robot that operates without water, intended for use in drought-prone areas. Presented the robot and findings at the Ventura County Science Fair, winning Best Engineering Project and a $500 scholarship from Cal-NRG.',
    tags: ['Mechanical Design', 'SolidWorks', 'Renewable Energy', 'Team Leadership'],
  },
  {
    title: 'Solar Autoclave for Off-Grid Surgical Sterilization',
    description: 'Researched solar-powered autoclaves as a way to reduce surgical site infections in off-grid areas of Africa. Co-authored a research paper and delivered a 12-minute group presentation with oral defense, as part of a 3-person research team.',
    tags: ['Research', 'Renewable Energy', 'Public Health', 'Presentations'],
  },
];
---

<Layout title="Projects — Baptiste Garderes" description="Engineering projects by Baptiste Garderes">
  <section class="page">
    <div class="container">
      <h1>Projects</h1>
      <p class="sub">A collection of things I've built — software, hardware, and everything in between.</p>
      <div class="grid">
        {projects.map(p => <ProjectCard {...p} />)}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page { padding: 4rem 2rem 6rem; }
  .container { max-width: 1100px; margin: 0 auto; }
  h1 { font-size: 2.5rem; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 0.75rem; }
  .sub { color: var(--muted); font-size: 1rem; margin-bottom: 3rem; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.25rem; }
</style>
