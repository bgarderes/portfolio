---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = [
  {
    title: 'Project One',
    description: 'Replace this with a real description. What does it do? What was the challenge? What did you learn?',
    tags: ['Python', 'ML', 'FastAPI'],
    github: 'https://github.com/bgarderes',
  },
  {
    title: 'Project Two',
    description: 'Replace this with a real description. What does it do? What was the challenge? What did you learn?',
    tags: ['C++', 'Embedded', 'RTOS'],
    github: 'https://github.com/bgarderes',
  },
  {
    title: 'Project Three',
    description: 'Replace this with a real description. What does it do? What was the challenge? What did you learn?',
    tags: ['React', 'TypeScript', 'Node.js'],
    github: 'https://github.com/bgarderes',
    demo: '#',
  },
  {
    title: 'Project Four',
    description: 'Replace this with a real description. What does it do? What was the challenge? What did you learn?',
    tags: ['Rust', 'WebAssembly'],
    github: 'https://github.com/bgarderes',
  },
];
---

<Layout title="Projects — Baptiste Garderes" description="Engineering projects by Baptiste Garderes">
  <section class="page">
    <div class="container">
      <h1>Projects</h1>
      <p class="sub">A collection of things I've built — software, hardware, and everything in between.</p>
      <div class="grid">
        {projects.map(p => <ProjectCard {...p} />)}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page { padding: 4rem 2rem 6rem; }
  .container { max-width: 1100px; margin: 0 auto; }
  h1 { font-size: 2.5rem; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 0.75rem; }
  .sub { color: var(--muted); font-size: 1rem; margin-bottom: 3rem; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.25rem; }
</style>
