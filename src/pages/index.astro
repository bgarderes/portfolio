---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const base = import.meta.env.BASE_URL;

const featured = [
  {
    title: 'Project One',
    description: 'A short description of what this project does and what problem it solves.',
    tags: ['Python', 'ML', 'FastAPI'],
    github: 'https://github.com/baptistegarderes',
  },
  {
    title: 'Project Two',
    description: 'A short description of what this project does and what problem it solves.',
    tags: ['C++', 'Embedded', 'RTOS'],
    github: 'https://github.com/baptistegarderes',
  },
  {
    title: 'Project Three',
    description: 'A short description of what this project does and what problem it solves.',
    tags: ['React', 'TypeScript', 'Node.js'],
    github: 'https://github.com/baptistegarderes',
    demo: '#',
  },
];
---

<Layout>
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">Hey, I'm Baptiste 👋</p>
      <h1>Engineering student<br /><span>building things that matter.</span></h1>
      <p class="sub">I design and build software &amp; hardware projects — from embedded systems to full-stack web apps.</p>
      <div class="cta">
        <a href={`${base}projects`} class="btn-primary">View projects</a>
        <a href="https://github.com/baptistegarderes" target="_blank" rel="noopener" class="btn-ghost">GitHub</a>
      </div>
    </div>
    <div class="hero-bg"></div>
  </section>

  <section class="featured">
    <div class="container">
      <h2>Featured projects</h2>
      <div class="grid">
        {featured.map(p => <ProjectCard {...p} />)}
      </div>
      <div class="see-all">
        <a href={`${base}projects`}>See all projects →</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 7rem 2rem 6rem;
    text-align: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(108,138,255,0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner { position: relative; max-width: 700px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 1.25rem; }

  .eyebrow { color: var(--accent); font-size: 0.95rem; font-weight: 500; }

  h1 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; line-height: 1.15; letter-spacing: -0.03em; }
  h1 span { color: var(--accent); }

  .sub { color: var(--muted); font-size: 1.1rem; line-height: 1.7; max-width: 520px; }

  .cta { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }

  .btn-primary {
    background: var(--accent); color: #fff;
    padding: 0.75rem 1.75rem; border-radius: 8px;
    text-decoration: none; font-weight: 600; font-size: 0.95rem;
    transition: opacity 0.2s;
  }
  .btn-primary:hover { opacity: 0.85; }

  .btn-ghost {
    border: 1px solid var(--border); color: var(--text);
    padding: 0.75rem 1.75rem; border-radius: 8px;
    text-decoration: none; font-weight: 500; font-size: 0.95rem;
    transition: border-color 0.2s;
  }
  .btn-ghost:hover { border-color: var(--accent-dim); }

  .featured { padding: 4rem 2rem 6rem; }
  .container { max-width: 1100px; margin: 0 auto; }

  h2 { font-size: 1.5rem; font-weight: 700; margin-bottom: 2rem; }

  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.25rem; }

  .see-all { margin-top: 2rem; text-align: center; }
  .see-all a { color: var(--accent); text-decoration: none; font-size: 0.95rem; }
  .see-all a:hover { text-decoration: underline; }
</style>
